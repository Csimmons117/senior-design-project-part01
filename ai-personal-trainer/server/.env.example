# Copy this file to .env and fill in real values.
# Do not commit your real .env file.

# Local development
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:5173,http://127.0.0.1:8000

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# AI provider
# Use false when a real Groq key is available.
# Use true to run the app offline with mock trainer responses.
AI_MOCK=false
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Optional email settings for password reset.
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user
# SMTP_PASS=your-pass
# FROM_EMAIL=noreply@yourdomain.com
# DOMAIN=yourdomain.com
