# Copy to .env and fill in values.

# Set to true to skip all external AI calls (offline / no key).
# AI_MOCK=false

# Required when AI_MOCK is not true — from https://console.groq.com/
GROQ_API_KEY=

# Optional: Groq model id (see Groq docs). Defaults to llama-3.3-70b-versatile.
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional
# PORT=4000
# JWT_SECRET=change-me-in-production
